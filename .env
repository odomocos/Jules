# The full URL to your n8n webhook for handling audio chunks and translation events
VITE_N8N_WEBHOOK_URL="https://your-n8n.example.com/webhook/voice"

# The default target language for translation (e.g., 'en-US', 'ro-RO')
VITE_DEFAULT_TARGET_LANG="ro-RO"

# Set to "true" to use Server-Sent Events (SSE) for receiving translations.
# Set to "false" to use polling.
VITE_USE_SSE="true"
